#pragma once

/**
 * \file turner/config.hpp
 * Turner library building configuration
 */


#define __turner_begin  namespace turner { inline namespace v0 {
#define __turner_end    }} // namespace turner::v0

__turner_begin

/**
 * Turner library version as string (turner/{VERSION}).
 */
inline constexpr const char version[] = "turner/@PROJECT_VERSION@";

#if _MSC_VER
  inline constexpr const bool is_msvc_compiler = true;
  inline constexpr const bool is_gnuc_compiler = false;
#elif __GNUC__
  inline constexpr const bool is_msvc_compiler = false;
  inline constexpr const bool is_gnuc_compiler = true;
#endif

#if _DEBUG
  inline constexpr const bool is_debug_build = true;
#else
  inline constexpr const bool is_debug_build = false;
#endif

__turner_end
